{
    "name": "jira-rice-farm",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "deploy": "tsc -b && vite build && node scripts/update-manifest.js && gh-pages -d dist -b main",
        "lint": "eslint . --ext js,ts,tsx --report-unused-disable-directives --max-warnings 0",
        "typecheck": "tsc --noEmit",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "validate": "npm run lint && npm run typecheck && npm run test && npm run build"
    },
    "dependencies": {
        "jsdom": "^29.1.1",
        "mobx-react-lite": "^4.1.1",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-modal": "^3.16.3",
        "use-debounce": "^10.1.1"
    },
    "devDependencies": {
        "@crxjs/vite-plugin": "^2.6.1",
        "@eslint/js": "^10.0.1",
        "@types/chrome": "^0.1.43",
        "@types/node": "^24.12.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-modal": "^3.16.3",
        "@vitejs/plugin-react": "^6.0.1",
        "better-npm-audit": "^3.11.0",
        "eslint": "^10.3.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "gh-pages": "^6.3.0",
        "globals": "^17.6.0",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.12",
        "vite-plugin-svgr": "^5.2.0",
        "vite-plugin-zip-pack": "^1.2.4",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.8"
    }
}
